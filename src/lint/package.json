{
  "name": "@gmloop/lint",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./test-support": {
      "import": "./dist/test/rules/index.js",
      "types": "./dist/test/rules/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:types": "tsc -b tsconfig.json",
    "clean:types": "rm -rf dist",
    "test": "pnpm run build:types && node --test 'dist/test/**/*.test.js'"
  },
  "dependencies": {
    "@gmloop/core": "workspace:*",
    "@gmloop/fixture-runner": "workspace:*",
    "@gmloop/parser": "workspace:*"
  },
  "peerDependencies": {
    "eslint": ">=9.39.0 <10"
  },
  "devDependencies": {
    "@gmloop/format": "workspace:*",
    "eslint": "^9.39.1",
    "eslint-min": "npm:eslint@9.39.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.28.0"
}
