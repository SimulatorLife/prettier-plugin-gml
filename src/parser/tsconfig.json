{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "baseUrl": ".",
    "allowJs": true,
    "paths": {
      "@gmloop/cli": ["../cli/index.ts"],
      "@gmloop/core": ["../core/index.ts"],
      "@gmloop/parser": ["./index.ts"],
      "@gmloop/format": ["../format/index.ts"],
      "@gmloop/refactor": ["../refactor/index.ts"],
      "@gmloop/runtime-wrapper": ["../runtime-wrapper/index.ts"],
      "@gmloop/transpiler": ["../transpiler/index.ts"]
    }
  },
  "references": [{ "path": "../core" }],
  "include": ["*.ts", "src/**/*.ts", "test/**/*.ts", "generated/**/*.js", "src/**/*.d.ts"],
  "exclude": ["dist"]
}
