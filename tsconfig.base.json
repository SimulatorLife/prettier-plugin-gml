{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@gmloop/core": ["src/core/index.ts"],
      "@gmloop/parser": ["src/parser/index.ts"],
      "@gmloop/format": ["src/format/index.ts"],
      "@gmloop/fixture-runner": ["src/fixture-runner/index.ts"],
      "@gmloop/lint": ["src/lint/index.ts"],
      "@gmloop/semantic": ["src/semantic/index.ts"],
      "@gmloop/transpiler": ["src/transpiler/index.ts"],
      "@gmloop/refactor": ["src/refactor/index.ts"],
      "@gmloop/runtime-wrapper": ["src/runtime-wrapper/index.ts"],
      "@gmloop/cli": ["src/cli/index.ts"]
    },
    "lib": ["ES2023"],
    "moduleDetection": "force",
    "types": ["node"],
    "typeRoots": ["./types", "./node_modules/@types"],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "sourceMap": true,
    "composite": true
  }
}
