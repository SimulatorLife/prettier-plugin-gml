{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "paths": {
      "@gmloop/core": ["src/core/index.ts"],
      "@gmloop/parser": ["src/parser/index.ts"],
      "@gmloop/format": ["src/format/index.ts"],
      "@gmloop/lint": ["src/lint/index.ts"],
      "@gmloop/semantic": ["src/semantic/index.ts"],
      "@gmloop/transpiler": ["src/transpiler/index.ts"],
      "@gmloop/refactor": ["src/refactor/index.ts"],
      "@gmloop/runtime-wrapper": ["src/runtime-wrapper/index.ts"],
      "@gmloop/cli": ["src/cli/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "test/**/*.ts",
    "types/*.d.ts",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vendor",
    "src/**/dist",
    "src/parser/generated"
  ]
}
