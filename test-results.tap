        /// @description De Morgan’s law: !(foo or bar) == !foo and !bar.
        /// @param {bool} foo
        /// @param {bool} bar
        /// @returns {bool}
        function scr_logic_demorgan_and(foo, bar) {
            return (!foo) and (!bar);
        }
        
        /// @description De Morgan’s law: !(foo and bar) == !foo or !bar.
        /// @param {bool} foo
        /// @param {bool} bar
        /// @returns {bool}
        function scr_logic_demorgan_or(foo, bar) {
