      failureType: 'testCodeFailure'
      error: |-
        test-argument-docs output must match expected text byte-for-byte.
        + actual - expected
        ... Skipped lines
        
          '/// @description Create collectible particles and inherit\n' +
            '\n' +
            '/// @function scr_bezier_4(x1, y1, x2, y2, x3, y3, x4, y4, width, steps, color)\n' +
            'function scr_bezier_4(argument0, argument1, argument2, argument3, argument4, argument5, argument6, argument7, argument8, argument9, argument10) {\n' +
            '    var x1 = argument0;\n' +
        ...
            '\n' +
