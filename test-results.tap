        /// @param {bool} foo
        /// @param {bool} bar
        /// @param {bool} baz
        /// @param {bool} qux
        /// @returns {bool}
        function scr_logic_guard_extraction(foo, bar, baz, qux) {
            return (foo or bar or baz) and qux;
